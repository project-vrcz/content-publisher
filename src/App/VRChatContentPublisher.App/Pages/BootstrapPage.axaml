<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:pages="clr-namespace:VRChatContentPublisher.App.ViewModels.Pages"
             xmlns:localization="clr-namespace:VRChatContentPublisher.App.Localization;assembly=VRChatContentPublisher.App.Localization"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="pages:BootstrapPageViewModel"
             x:Class="VRChatContentPublisher.App.Pages.BootstrapPage">

    <Interaction.Behaviors>
        <AttachedToVisualTreeTrigger>
            <InvokeCommandAction Command="{Binding LoadCommand}" />
        </AttachedToVisualTreeTrigger>
    </Interaction.Behaviors>

    <Grid RowDefinitions="*,Auto,*">
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" Spacing="16">
            <ProgressBar Classes="circular" IsIndeterminate="True" HorizontalAlignment="Center" />
            <TextBlock Text="{I18N {x:Static localization:LangKeys.Pages_Bootstrap_Loading_Text}}"
                       HorizontalAlignment="Center" />
        </StackPanel>
    </Grid>
</UserControl>